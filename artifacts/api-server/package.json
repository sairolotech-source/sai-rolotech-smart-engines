{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --tsconfig tsconfig.json src/index.ts",
    "start": "NODE_ENV=production tsx --tsconfig tsconfig.json src/index.ts",
    "build": "tsx --tsconfig tsconfig.json build.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --tsconfig tsconfig.json src/tests/calc-validator.test.ts && tsx --tsconfig tsconfig.json src/tests/engineering-integration.test.ts",
    "test:calc": "tsx --tsconfig tsconfig.json src/tests/calc-validator.test.ts",
    "test:integration": "tsx --tsconfig tsconfig.json src/tests/engineering-integration.test.ts"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@serialport/parser-readline": "^13.0.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "cors": "^2.8.5",
    "drizzle-orm": "catalog:",
    "express": "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "jose": "^5.10.0",
    "jszip": "^3.10.1",
    "multer": "^2.0.0",
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1",
    "pg": "^8.20.0",
    "serialport": "^13.0.0",
    "systeminformation": "^5.25.11",
    "uuid": "^11.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.1",
    "@types/multer": "^1.4.12",
    "@types/node": "catalog:",
    "esbuild": "0.27.3",
    "tsx": "catalog:",
    "typescript": "~5.9.2"
  }
}
